# ============================================================================
# Google Cloud & Gemini Configuration
# ============================================================================

# OPTION A: Vertex AI (Recommended for BSNL Production)
# Required: GOOGLE_CLOUD_PROJECT, GOOGLE_CLOUD_LOCATION
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# OPTION B: Google AI Studio API Key (Recommended for Quick Testing)
# Required: GOOGLE_API_KEY (Leave empty if using Vertex AI)
GOOGLE_API_KEY=

# Model Settings
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_VOICE=Puck

# Initial message and conversation settings
INITIAL_MESSAGE=Hi there!

# ============================================================================
# Asterisk ARI Configuration (BSNL + Asterisk Integration)
# ============================================================================
# Asterisk REST Interface (ARI) base URL
ARI_BASE_URL=http://localhost:8088

# ARI authentication credentials
ARI_USERNAME=asterisk
ARI_PASSWORD=asterisk

# Asterisk Stasis application name (must match extensions.conf)
# Example dialplan: exten => _X.,n,Stasis(convobridge,INBOUND,${CALLERID(num)},${EXTEN})
ARI_APP_NAME=convobridge

# ============================================================================
# RTP Configuration (Asterisk External Media)
# ============================================================================
# Local IP for RTP binding (use 0.0.0.0 to listen on all interfaces)
RTP_LOCAL_IP=0.0.0.0

# RTP port range for external media channels
RTP_LOCAL_PORT_RANGE_START=10000
RTP_LOCAL_PORT_RANGE_END=20000

# ============================================================================
# Service Configuration
# ============================================================================
SERVICE_LOG_LEVEL=INFO
ENABLE_TRANSCRIPT_LOGGING=true
ENABLE_REDIS_STATE=false

# Optional: Redis URL for distributed session state (for scaling beyond single instance)
# REDIS_URL=redis://localhost:6379/0

# Concurrency & Call Duration
MAX_CONCURRENT_CALLS=10
CALL_DURATION_LIMIT_SECONDS=300
SILENCE_PADDING_MS=100

# Multi-tenancy (Optional)
COMPANY_SLUG=default

# ============================================================================
# PostgreSQL Database Configuration (Optional)
# ============================================================================
# For call transcripts, metrics, and session history
DB_HOST=localhost
DB_PORT=5432
DB_NAME=convobridge
DB_USER=postgres
DB_PASS=
ENABLE_DB_LOGGING=false

# ============================================================================
# Telegram Integration (Optional)
# ============================================================================
# For webhook notifications and audit logs
TELEGRAM_TOKEN=
TELEGRAM_ADMINS=

# ============================================================================
# System Instruction for Gemini
# ============================================================================
# Custom system prompt for the AI agent
SYSTEM_INSTRUCTION="You are an AI assistant integrated with Asterisk telephony. Respond naturally and conversationally."

